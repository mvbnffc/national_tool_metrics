# Python
__pycache__/
*.py[cod]
*$py.class

# Jupyter
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Local environment files
.env
.env.*

# Logs
*.log

# Operating system files
.DS_Store
Thumbs.db

# Large/local data files.
# Keep the directory skeleton via .gitkeep files, but avoid committing raw data,
# boundary data, and generated results by accident.
data/boundaries/**/*
data/raw/**/*
results/**/*
!data/boundaries/**/
!data/raw/**/
!results/**/
!data/boundaries/**/.gitkeep
!data/raw/**/.gitkeep
!results/**/.gitkeep

